{
  "name": "@borealismark/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the BorealisMark Protocol API — AI Trust Infrastructure on Hedera Hashgraph",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": ["borealismark", "ai", "trust", "audit", "hedera", "blockchain", "api", "sdk"],
  "author": "Borealis Protocol <support@borealisprotocol.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/borealisprotocol/borealismark-api"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
